# Confluent Kafka Configuration
# Copy this file to .env and fill in your actual values

# Kafka Bootstrap Servers
# Example: pkc-xyz123.us-east-2.aws.confluent.cloud:9092
KAFKA_BOOTSTRAP_SERVERS=your_bootstrap_server_here

# Kafka SASL Username (API Key from Confluent Cloud)
KAFKA_USERNAME=your_kafka_api_key_here

# Kafka SASL Password (API Secret from Confluent Cloud)
KAFKA_PASSWORD=your_kafka_api_secret_here

# Schema Registry URL
# Example: https://psrc-abc456.us-east1.gcp.confluent.cloud
SCHEMA_REGISTRY_URL=your_schema_registry_url_here

# Schema Registry Username (API Key)
SCHEMA_REGISTRY_USERNAME=your_schema_registry_api_key_here

# Schema Registry Password (API Secret)
SCHEMA_REGISTRY_PASSWORD=your_schema_registry_api_secret_here
